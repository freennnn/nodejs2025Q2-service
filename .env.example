
CRYPT_SALT=10
JWT_SECRET_KEY=secret123123
JWT_SECRET_REFRESH_KEY=secret123123
TOKEN_EXPIRE_TIME=1h
TOKEN_REFRESH_EXPIRE_TIME=24h

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
POSTGRES_DB=home-library
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# =============================================================================
# APPLICATION CONFIGURATION  
# =============================================================================
NODE_ENV=development
PORT=4000

# Database connection string - constructed from variables above
# Don't edit this unless you need a custom format
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=public

# =============================================================================
# DOCKER CONTAINER CONFIGURATION
# =============================================================================
# Container names (customize to avoid conflicts)
POSTGRES_CONTAINER_NAME=home-library-postgres
APP_CONTAINER_NAME=home-library-app

# Network name (customize for isolation)
NETWORK_NAME=home-library-network

# =============================================================================
# PRODUCTION DOCKER HUB IMAGES
# =============================================================================
# Used only by docker-compose.prod.yml
POSTGRES_IMAGE=freennnn/nodejs2025q2-service-postgres:latest
APP_IMAGE=freennnn/nodejs2025q2-service-app:latest

# =============================================================================
# PRODUCTION OVERRIDES
# =============================================================================
# Uncomment and modify for production deployment:
# NODE_ENV=production
# POSTGRES_PASSWORD=your_secure_production_password
# POSTGRES_DB=home_library_prod
# NETWORK_NAME=home-library-network-prod
# POSTGRES_CONTAINER_NAME=home-library-postgres-prod  
# APP_CONTAINER_NAME=home-library-app-prod