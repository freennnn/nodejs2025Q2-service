{
  "name": "home-library",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.14.0"
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --testMatch \"<rootDir>/*.spec.ts\" --noStackTrace --runInBand",
    "test:auth": "cross-env TEST_MODE=auth jest --testPathIgnorePatterns refresh.e2e.spec.ts --noStackTrace --runInBand",
    "test:refresh": "cross-env TEST_MODE=auth jest --testPathPattern refresh.e2e.spec.ts --noStackTrace --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "security:audit": "npm audit",
    "security:audit:fix": "npm audit fix",
    "security:docker:app": "docker scout cves home-library-app:latest",
    "security:docker:db": "docker scout cves home-library-postgres:latest",
    "security:docker:all": "npm run security:docker:app && npm run security:docker:db",
    "security:all": "npm run security:audit && npm run security:docker:all",
    "prisma:generate:dev": "cross-env DATABASE_URL=postgresql://postgres:postgres@localhost:5432/home-library?schema=public prisma generate",
    "prisma:migrate:dev": "cross-env DATABASE_URL=postgresql://postgres:postgres@localhost:5432/home-library?schema=public prisma migrate deploy",
    "dev:db": "docker-compose --env-file .env.dev up postgres -d",
    "dev:setup": "npm run prisma:generate:dev && npm run prisma:migrate:dev",
    "dev:hybrid": "npm run dev:db && npm run dev:setup && npm run start:dev",
    "docker:up:dev": "docker-compose --env-file .env.dev up",
    "docker:build:dev": "docker-compose --env-file .env.dev up --build",
    "docker:up:prod": "docker-compose -f docker-compose.prod.yml --env-file .env.prod up",
    "docker:build:prod": "docker-compose -f docker-compose.prod.yml --env-file .env.prod up --build",
    "docker:down": "docker-compose down",
    "docker:build:app": "docker build --target production -t freennnn/nodejs2025q2-service-app:latest .",
    "docker:push:app": "docker push freennnn/nodejs2025q2-service-app:latest",
    "docker:build:push:app": "npm run docker:build:app && npm run docker:push:app",
    "docker:build:postgres": "docker build -f Dockerfile.postgres -t freennnn/nodejs2025q2-service-postgres:latest .",
    "docker:push:postgres": "docker push freennnn/nodejs2025q2-service-postgres:latest",
    "docker:build:push:postgres": "npm run docker:build:postgres && npm run docker:push:postgres"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.2.0",
    "@prisma/client": "^6.9.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.5",
    "js-yaml": "^4.1.0",
    "reflect-metadata": "^0.2.1",
    "rimraf": "^5.0.5",
    "rxjs": "^7.8.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.24",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "http-status-codes": "^2.3.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "prisma": "^6.9.0",
    "rimraf": "^5.0.5",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}