# Postgress db initialization values for Docker (these values also should be used if db is created manually on local machine)
    POSTGRES_DB=home-library
    POSTGRES_USER=postgres
    POSTGRES_PASSWORD=postgres

# Application 
    NODE_ENV=development
    PORT=4000
    # Database connection string - constructed from variables above, but manually, as interpolation (in Prisma config) won't work
    # Pattern: DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@{HOST}:5432/${POSTGRES_DB}?schema=public
    # HOST === 'localhost' for local db or name of postgres service ('postgres', set in docker-compose.yml files)
    DATABASE_URL=postgresql://posgtres:postgres@localhost:5432/home-library?schema=public

    CRYPT_SALT=10
    JWT_SECRET_KEY=secret123123
    JWT_SECRET_REFRESH_KEY=secret123123
    TOKEN_EXPIRE_TIME=30m
    TOKEN_REFRESH_EXPIRE_TIME=24h

# Docker compose configuration
    POSTGRES_CONTAINER_NAME=home-library-postgres
    APP_CONTAINER_NAME=home-library-app
    NETWORK_NAME=home-library-network
    POSTGRES_PORT=5432

# Add to .env.dev and .env.prod:
LOG_LEVEL=DEBUG           # For dev: DEBUG, for prod: INFO or WARN
LOG_DIR=./logs           # Directory for log files inside container
LOG_MAX_FILE_SIZE=1024   # File size in KB before rotation (1MB)